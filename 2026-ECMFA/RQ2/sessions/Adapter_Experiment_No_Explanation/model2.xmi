<?xml version="1.0" encoding="UTF-8"?>
<adp:AdapterModel xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:adp="http://adapters.org/0.1" xsi:schemaLocation="http://adapters.org/0.1 Adapters.ecore" xmi:id="_3xMQABQAEfGgiLaW5H9bqA" name="AdaptiveClassDiagrams" ecore="AdaptiveClassDiagrams.ecore" transformation="trafos/AdaptiveClassDiagrams.henshin">
  <adapters xmi:id="_3xMQARQAEfGgiLaW5H9bqA" name="InhByDelegation">
